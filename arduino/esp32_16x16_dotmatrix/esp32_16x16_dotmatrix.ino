/*
 * ESP32 + 16x16 LED 点阵屏 (MAX7219 驱动)
 * 
 * 硬件连接:
 * ESP32     MAX7219
 * GPIO 23   -> DIN (数据)
 * GPIO 18   -> CLK (时钟)
 * GPIO 5    -> CS  (片选)
 * 3.3V      -> VCC
 * GND       -> GND
 * 
 * 依赖库: LedControl by Eberhard Fahle
 * 安装：Arduino IDE -> 工具 -> 管理库 -> 搜索 "LedControl" -> 安装
 */

#include <LedControl.h>

// 引脚定义
#define DIN_PIN   23
#define CLK_PIN   18
#define CS_PIN    5

// 点阵屏数量（16x16 通常是 4 个 8x8 级联）
#define NUM_DEVICES 4

// 创建 LedControl 对象
LedControl lc = LedControl(DIN_PIN, CLK_PIN, CS_PIN, NUM_DEVICES);

// 开机延迟
#define DELAY_TIME 50

// 字模数据 (8x8 字体，16x16 需要组合)
const byte char_8x8[][8] = {
  // 0-9
  {0x00,0x00,0x3E,0x41,0x41,0x41,0x3E,0x00}, // 0
  {0x00,0x00,0x42,0x7F,0x40,0x40,0x00,0x00}, // 1
